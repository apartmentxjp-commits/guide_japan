# guide_japan — Environment Variables
# Copy this to .env and fill in your values
# .env is gitignored — never commit it

# ── AI Providers ─────────────────────────────────────────────────────────────
# Primary: OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fallback: Groq (https://console.groq.com) — free tier
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model selection (defaults shown — change if needed)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
GROQ_MODEL=llama-3.1-70b-versatile

# ── GitHub (for publishing articles to GitHub Pages) ─────────────────────────
# Personal access token with 'contents: write' scope
# Create at: https://github.com/settings/tokens
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=apartmentxjp-commits/guide_japan

# ── Site Config ───────────────────────────────────────────────────────────────
SITE_BASE_URL=https://guide-japan.tacky-consulting.com
AKIYA_URL=https://akiya.tacky-consulting.com
SUBSTACK_URL=https://guidejapanenglish.substack.com

# ── Database ──────────────────────────────────────────────────────────────────
# Development: SQLite (default, no setup needed)
DATABASE_URL=sqlite:////app/data/guide_japan.db

# Production: PostgreSQL (optional)
# DATABASE_URL=postgresql://user:password@host:5432/guide_japan
